# ==============================
# Server
# ==============================
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/provisa
CLIENT_URL=http://localhost:5173

# ==============================
# EmailJS (for contact + appointment)
# ==============================
EMAILJS_SERVICE_ID=
EMAILJS_PUBLIC_KEY=

# Appointment template (used in Appointment forms)
EMAILJS_TEMPLATE_ID=

# Contact template (used in Contact forms)
EMAILJS_CONTACT_TEMPLATE_ID=

# ==============================
# Recipient
# Send all contact + appointment messages to this single inbox
# ==============================
MARKETING_INBOX_EMAIL=marketing@provisa.com.np

