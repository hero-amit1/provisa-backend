{
    "env": {
        "node": true,
        "es2021": true
    },
    "extends": [
        "eslint:recommended"
    ],
    "parserOptions": {
        "ecmaVersion": 2021,
        "sourceType": "commonjs"
    },
    "rules": {
        "@typescript-eslint/no-require-imports": "off",
        "no-undef": "off"
    }
}